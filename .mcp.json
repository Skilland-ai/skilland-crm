{
  "mcpServers": {
    "postgres": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres", "${PG_DATABASE_URL}"],
      "env": {}
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["@playwright/mcp@latest", "--no-sandbox", "--headless"],
      "env": {}
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": {}
    },
    "twenty-crm": {
      "type": "streamable-http",
      "url": "https://crm.skilland.ai/mcp",
      "headers": {
        "Authorization": "Bearer ${TWENTY_API_KEY}"
      }
    }
  }
}
